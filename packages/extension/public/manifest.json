{
  "manifest_version": 3,
  "name": "BoardBack Capture Tool",
  "version": "1.0.1",
  "description": "Capture tabs and bookmarks to your BoardBack workspace.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "https://boardback-web.vercel.app/*",
      "http://localhost:3000/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://boardback-web.vercel.app/*",
        "http://localhost:3000/*"
      ],
      "js": ["content.js"]
    }
  ]
}
