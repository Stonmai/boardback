{
  "manifest_version": 3,
  "name": "BoardBack Capture Tool",
  "version": "1.0.2",
  "description": "A local-first visual workspace for organizing browser tabs and bookmarks on an infinite canvas.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*"
      ],
      "js": ["content.js"]
    }
  ]
}
